Options -Indexes -MultiViews
RewriteEngine On

# 1. Point BOTH 404 (Not Found) and 403 (Forbidden) errors to your custom theme page
ErrorDocument 403 /fayenor/public/404.php
ErrorDocument 404 /fayenor/public/404.php

# 2. If someone types just "/public/", automatically send them to the login page!
RewriteRule ^public/?$ /fayenor/public/login [R=301,L]

# ========================================================================
# REMOVE .PHP EXTENSION FROM URLS
# ========================================================================

# External Redirect: If a user types a link ending in .php, redirect them to the clean URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Internal Routing: Tell Apache to silently look for the .php file
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]